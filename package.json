{
  "name": "nz-ecom",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:ingestion": "turbo dev --filter=ingestion",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "collect": "bun run --cwd apps/ingestion src/collect-all.ts",
    "collect:fast": "bun run --cwd apps/ingestion src/collect-all.ts --skip=groceries",
    "db:push": "bun run --cwd packages/db db:push",
    "db:seed": "bun run --cwd packages/db db:seed",
    "db:studio": "bun run --cwd packages/db db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3",
    "ultracite": "7.3.2"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
