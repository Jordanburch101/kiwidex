    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "^5.9.3"
  }
